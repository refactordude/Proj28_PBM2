# Config files containing secrets (per D-11: settings.yaml holds plaintext passwords/api_keys)
config/settings.yaml
config/auth.yaml
config/starter_prompts.yaml
config/overview.yaml
config/presets.yaml
.env

# Phase 03: per-platform markdown content pages (D-28 — gitignored, .gitkeep retained)
# NOTE: a bare `content/` rule alone would block `!content/platforms/.gitkeep` from
# matching (git short-circuits descent into ignored directories). The two
# `!content/` and `!content/platforms/` re-includes restore traversal so the
# negation on .gitkeep actually applies. All other files inside content/ remain
# ignored thanks to the wildcard match below.
content/
!content/
!content/platforms/
content/platforms/*
!content/platforms/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
logs/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
